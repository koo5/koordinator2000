# Example environment configuration for Koordinator
# Copy this file to .env and update the values

# GraphQL endpoint for Hasura (MUST have VITE_ prefix for client access)
VITE_PUBLIC_GRAPHQL_ENDPOINT="your-hasura-instance.hasura.app/v1/graphql"
VITE_PUBLIC_URL="http://localhost:5000"
VITE_PUBLIC_BASE_URL="/"

# Client GraphQL headers: NO admin secret — the browser uses the user's JWT.
VITE_PUBLIC_GRAPHQL_HEADERS='{"content-type":"application/json"}'

# Hasura admin secret (server-side only)
HASURA_ADMIN_SECRET="your-hasura-admin-secret"

# GitHub OAuth (Arctic). Create an app at https://github.com/settings/developers
# Callback URL: http://localhost:5533/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Magic-link email via Resend (https://resend.com, free tier ~100/day).
# Unset => dev mode: the link is logged + returned in the response.
RESEND_API_KEY=""
EMAIL_FROM="Koordinator <onboarding@resend.dev>"

# Google OAuth (Arctic, PKCE). https://console.cloud.google.com
# Redirect URI: http://localhost:5533/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App keys - generate using generate_key_pair.mjs
# This should be a server-side environment variable - NOT public!
MY_APP_KEYS='{"private":{...},"public":{...}}'