# Koordinator root environment — copy to .env and fill in real secrets.
# Generate secrets with: openssl rand -hex 24

# --- Postgres (self-hosted, see docker-compose.yml) ---
POSTGRES_USER=koordinator
POSTGRES_PASSWORD=change-me-openssl-rand-hex-24
POSTGRES_DB=koordinator

# Connection string as seen FROM THE HOST (host tools use 127.0.0.1:5434).
# Containers override this with postgres:5432 via docker-compose.
DATABASE_URL=postgres://koordinator:change-me@127.0.0.1:5434/koordinator

# --- Hasura ---
HASURA_ADMIN_SECRET=change-me-openssl-rand-hex-24
